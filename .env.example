# ===========================================
# Kame — Environment Variables
# Copy to .env and fill in your values
# ===========================================

# Database (Supabase/Neon free tier)
DATABASE_URL=postgresql://user:password@host:6543/kame?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/kame

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# FASHN AI Virtual Try-On (https://fashn.ai)
FASHN_API_KEY=your-fashn-api-key
FASHN_API_URL=https://api.fashn.ai/v1

# Cloudflare R2 (user photos + try-on results)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=kame-uploads
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001

# Server
PORT=3001
NODE_ENV=development

# CORS — restrict in production to your mobile app origin
# ALLOWED_ORIGIN=https://your-app-domain.com

# Waitlist Admin Dashboard
ADMIN_PASSWORD=your-admin-password-here
