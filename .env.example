# ===========================================
# Kame — Environment Variables
# Copy to .env and fill in your values
# ===========================================

# Database (Supabase/Neon free tier)
DATABASE_URL=postgresql://user:password@host:5432/kame

# Redis (Upstash free tier)
REDIS_URL=redis://default:password@host:6379

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# FASHN AI Virtual Try-On (https://fashn.ai)
FASHN_API_KEY=your-fashn-api-key
FASHN_API_URL=https://api.fashn.ai/v1

# AWS S3 (user photos + try-on results)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=kame-uploads
AWS_REGION=us-east-1

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001

# Server
PORT=3001
NODE_ENV=development
