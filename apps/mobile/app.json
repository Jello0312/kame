{
  "expo": {
    "name": "Kame",
    "slug": "kame",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "kame",
    "splash": {
      "backgroundColor": "#112836",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kame.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#112836"
      },
      "package": "com.kame.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
